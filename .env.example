# Network
CONTROL_HOST=0.0.0.0
CONTROL_PORT=19090

# Security
CONTROL_AUTH_TOKEN=replace-with-strong-token

# Local persistence fallback
CONTROL_DATA_FILE=./control-plane-data.json

# Storage backend
CONTROL_STORAGE_BACKEND=postgres
CONTROL_PG_DSN=postgres://USER:PASSWORD@POSTGRES_HOST:5432/DBNAME
CONTROL_PG_TABLE=control_plane_state

# Queue backend
CONTROL_QUEUE_BACKEND=redis_bullmq
CONTROL_QUEUE_JOURNAL_FILE=./control-plane-data.json.ledger-journal
CONTROL_REDIS_URL=redis://REDIS_HOST:6379
CONTROL_BULLMQ_QUEUE=grid-ledger-events
CONTROL_BULLMQ_WORKER_CONCURRENCY=8

# Runtime tuning
PRESENCE_TTL_SECONDS=40
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LEDGER_DECAY_ALPHA=0.9
MESSAGE_COOLDOWN_MS=2000
SESSION_PATH_EMA_ALPHA=0.7
